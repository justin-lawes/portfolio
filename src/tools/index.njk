---
layout: base.njk
title: Tools
permalink: /tools/
eleventyExcludeFromCollections: true
passwordHash: b17318c0e3fe363284ff1e72a005207efb4c0d15c788951d6de04cae06ead1d0
---
<div class="password-gate" id="passwordGate">
  <div class="password-gate-inner">
    <h1>Tools</h1>
    <p>This page is password protected.</p>
    <form id="passwordForm" autocomplete="off">
      <input type="password" id="passwordInput" placeholder="Enter password" autocomplete="off">
      <button type="submit">&rarr;</button>
    </form>
    <p class="password-error" id="passwordError" style="display:none">Incorrect password</p>
  </div>
</div>
<main id="main" class="tools" style="display:none">
  <div class="tools-content">
    <h1>Tools</h1>
    <p class="tools-intro">Apps and utilities for beta testing. Grab what you need and let me know how it goes.</p>

    {% for tool in collections.tools %}
    <a href="{{ tool.url | url }}" class="tool-card tool-card-link">
      <h2>{{ tool.data.title }}</h2>
      <p>{{ tool.data.description }}</p>
      <div class="tool-meta">
        <span class="tool-version">{{ tool.data.version }}</span>
        <span class="tool-platform">{{ tool.data.platform }}</span>
      </div>
    </a>
    {% endfor %}

  </div>
</main>
<script>
(function() {
  var hash = '{{ passwordHash }}';
  var key = 'pw_tools';
  if (sessionStorage.getItem(key) === hash) {
    document.getElementById('passwordGate').style.display = 'none';
    document.getElementById('main').style.display = '';
    return;
  }
  document.getElementById('passwordForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var pw = document.getElementById('passwordInput').value;
    crypto.subtle.digest('SHA-256', new TextEncoder().encode(pw)).then(function(buf) {
      var arr = Array.from(new Uint8Array(buf));
      var hex = arr.map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
      if (hex === hash) {
        sessionStorage.setItem(key, hash);
        document.getElementById('passwordGate').style.display = 'none';
        document.getElementById('main').style.display = '';
      } else {
        document.getElementById('passwordError').style.display = 'block';
        document.getElementById('passwordInput').value = '';
        document.getElementById('passwordInput').focus();
      }
    });
  });
})();
</script>
