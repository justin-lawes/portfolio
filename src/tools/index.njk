---
layout: base.njk
title: Tools
permalink: /tools/
eleventyExcludeFromCollections: true
---
<main id="main" class="tools">
  <div class="tools-content">
    <h1>Tools</h1>
    <p class="tools-intro">Apps and utilities for beta testing. Grab what you need and let me know how it goes.</p>

    {% for tool in collections.tools %}
    <a href="{{ tool.url | url }}" class="tool-card tool-card-link">
      <h2>{{ tool.data.title }}</h2>
      <p>{{ tool.data.description }}</p>
      <div class="tool-meta">
        <span class="tool-version">{{ tool.data.version }}</span>
        <span class="tool-platform">{{ tool.data.platform }}</span>
      </div>
    </a>
    {% endfor %}

  </div>
</main>
