---
layout: base.njk
activeNav: featured
---
<main id="main">
  <p class="page-intro">Justin Lawes is a freelance motion designer based in Portland, OR.<br>Say <a href="mailto:justin.lawes@gmail.com">hello</a>.</p>
  {% set projectOrder = [
    "54-superhuman",
    "10-chase-bliss", "11-agog",
    "01-blend", "02-perplexity", "03-bookboy", "04-sonos-beam", "05-msk",
    "06-mailchimp", "07-lark-magic-share", "08-whywater", "09-grails-iii",
    "12-googleedu", "13-sharpener", "20-exposure", "14-hootsuite",
    "16-something-savage-ipa", "15-reformation",
    "18-operator", "17-interiors-awards",
    "21-noodles", "19-pup-sneeze"
  ] %}
  <div class="project-grid">
    {%- for slug in projectOrder %}
    {%- for project in collections.projects %}
    {%- if project.fileSlug == slug %}
    <a href="{{ project.url | url }}" class="project-card{% if project.data.wide %} wide{% endif %}">
      <div class="project-image-wrap">
      {% if project.data.thumbnail %}
      <img class="project-image" src="{{ project.data.thumbnail | url }}" alt="{{ project.data.title }}" loading="lazy" decoding="async" sizes="(max-width: 480px) 100vw, 50vw"{% if project.data.thumbnailPosition or project.data.thumbnailScale or project.data.thumbnailOrigin %} style="{% if project.data.thumbnailPosition %}object-position: {{ project.data.thumbnailPosition }};{% endif %}{% if project.data.thumbnailScale %}transform: scale({{ project.data.thumbnailScale }});{% endif %}{% if project.data.thumbnailOrigin %}transform-origin: {{ project.data.thumbnailOrigin }};{% endif %}"{% endif %}>
      {% else %}
      <div class="project-image"></div>
      {% endif %}
      </div>
      <h3>{{ project.data.title }}</h3>
    </a>
    {%- endif %}
    {%- endfor %}
    {%- endfor %}
  </div>
  <script>
    var cards = document.querySelectorAll('.project-card');
    sessionStorage.setItem('projectNav', JSON.stringify(Array.from(cards).map(function(c) { return c.getAttribute('href'); })));
  </script>
</main>
